{
  "name": "sim-binding-sim-not-registered",
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPattern": "/sim/v1/bind",
    "bodyPatterns": [
      {
        "contains": "TESTSIM003"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "status": "FAILURE",
      "errorCode": "SIM_NOT_REGISTERED",
      "message": "Mobile number is not registered with any operator"
    }
  }
}